{
  "name": "@lexai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "exports": {
    "./trpc": {
      "types": "./src/trpc/router.ts",
      "import": "./dist/trpc/router.js"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@fastify/cors": "^11.0.0",
    "@lexai/ai": "workspace:*",
    "@lexai/shared": "workspace:*",
    "@prisma/client": "^6.5.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.6.0",
    "jose": "^6.0.10",
    "livekit-server-sdk": "^2.9.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "superjson": "^2.2.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "embedded-postgres": "18.4.0-beta.17",
    "prisma": "^6.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}